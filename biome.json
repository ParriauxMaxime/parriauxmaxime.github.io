{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useAltText": "warn",
        "useKeyWithClickEvents": "off",
        "useAnchorContent": "off",
        "noStaticElementInteractions": "off"
      },
      "correctness": {
        "noUnknownFunction": "off"
      },
      "suspicious": {
        "noShorthandPropertyOverrides": "off",
        "noUnknownAtRules": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "includes": ["src/**", "rsbuild.config.ts"]
  }
}
